# ==============================================================================
# FocusForge — Environment Variables
# Скопируйте в .env и заполните реальными значениями
# ==============================================================================

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_WEBHOOK_SECRET=change_me_to_random_secret_32_chars

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=focusforge
POSTGRES_USER=focusforge
POSTGRES_PASSWORD=change_me_strong_password

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=focusforge
MONGO_USER=focusforge
MONGO_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_strong_password

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=debug
SERVER_PORT=8080
WORKER_THREADS=4

# ── Domain ────────────────────────────────────────────────────────────────────
# URL, на который Telegram отправляет webhook
# В локальном режиме используйте ngrok или аналог
WEBHOOK_BASE_URL=https://your-domain.com

# Максимальное количество активных задач на пользователя
MAX_TASKS_PER_USER=500

# Rate limit: максимум запросов от одного пользователя в минуту
RATE_LIMIT_REQUESTS_PER_MINUTE=30
