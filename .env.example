# ==============================================================================
# FocusForge — переменные окружения
#
# Скопируйте: cp .env.example .env
# Заполните TELEGRAM_BOT_TOKEN, TELEGRAM_WEBHOOK_SECRET и пароли БД.
# ВАЖНО: пароли POSTGRES_PASSWORD и MONGO_PASSWORD должны совпадать
#        с паролями в configs/config_vars.yaml (pg_dsn / mongo_dsn).
# ==============================================================================

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_WEBHOOK_SECRET=change_me_to_random_secret_min32chars

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=focusforge
POSTGRES_USER=focusforge
POSTGRES_PASSWORD=change_me_postgres_password

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=focusforge
MONGO_USER=focusforge
MONGO_PASSWORD=change_me_mongo_password

# ── Redis (пароль не нужен в локальном dev) ───────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=debug
SERVER_PORT=8080
WORKER_THREADS=4
