# .devcontainer/.env.devcontainer
# Переменные окружения специфичные для Dev Container
# Эти значения используются docker-compose.devcontainer.yml

# Пароли для dev (не используйте в production)
POSTGRES_PASSWORD=secret_pg_password
MONGO_PASSWORD=secret_mongo_password
REDIS_PASSWORD=secret_redis_password

# Telegram (заполнить для тестирования webhook)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=dev_secret
